#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-unknown}"
remote_url="${2:-unknown}"

echo "[AgentSkills][HOOK][START] pre-push"
echo "Remote: $remote_name"
echo "URL: $remote_url"

protected=()
while IFS= read -r branch; do
  [[ -n "$branch" ]] && protected+=("$branch")
done < <(git config --local --get-all agentskills.protectedPushBranch || true)
if ((${#protected[@]} == 0)); then
  protected=(main master)
  source_label="default"
else
  source_label="git config"
fi

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -n "${remote_ref:-}" ]] || continue
  remote_branch="${remote_ref#refs/heads/}"

  for branch in "${protected[@]}"; do
    if [[ "$remote_ref" == "refs/heads/$branch" ]]; then
      echo "[AgentSkills][HOOK][BLOCKER] protected-push" >&2
      echo "Local ref: $local_ref" >&2
      echo "Remote ref: $remote_ref" >&2
      echo "Protected branch: $branch" >&2
      echo "Configured by: $source_label" >&2
      echo "Reason: Direct pushes to protected branches are prohibited." >&2
      echo "Resolution: Push a feature branch and merge through the project's review flow." >&2
      blocked=1
      break
    fi
  done

  if ((blocked == 0)); then
    echo "[AgentSkills][HOOK][PASS] push-ref"
    echo "Remote ref: $remote_ref"
  fi
done

if ((blocked == 1)); then
  echo "[AgentSkills][HOOK][END] pre-push: BLOCKER" >&2
  exit 1
fi

echo "[AgentSkills][HOOK][PASS] pre-push"
